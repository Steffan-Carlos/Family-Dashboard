# Google Calendar OAuth2
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/calendar/callback/google

# Microsoft Graph OAuth2
# Create at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5173/api/calendar/callback/microsoft
MICROSOFT_TENANT_ID=common

# Sync settings
SYNC_INTERVAL_MINUTES=15
